    async function importaDaCalendario(mode = 'tecnico') {
        if(!navigator.onLine) return alert("Connettiti per interrogare il calendario!");
        const pin = localStorage.getItem('tmc_auth_token');
        const body = { action: "get_calendar", pin };
        if(mode === 'tecnico') { const t1 = document.getElementsByName('tecnico_1')[0].value; if(!t1) return alert("Inserisci un tecnico!"); body.tecnico = t1; }
        else if(mode === 'ticket') { const tck = document.getElementById('n_rapporto_input').value; if(!tck) return alert("Scrivi un numero di ticket!"); body.ticket = tck; }
        document.getElementById('loading-overlay').style.display = 'flex';
        document.getElementById('loading-text').innerText = "Ricerca in corso...";
        try { const response = await fetch(APP_SCRIPT_URL, { method:"POST", headers:{'Content-Type':'text/plain;charset=utf-8'}, body: JSON.stringify(body) }); const data = await response.json(); document.getElementById('loading-overlay').style.display = 'none'; if(data.results && data.results.length > 0) { if(data.results.length === 1) applicaDatiCalendario(data.results[0]); else mostraSelezioneTicket(data.results); } else { alert(mode==='tecnico' ? "Nessun evento OGGI per questo tecnico." : "Nessun evento per questo Ticket."); } } catch(e) { document.getElementById('loading-overlay').style.display = 'none'; alert("Errore connessione."); }
    }
    function mostraSelezioneTicket(results) { const container = document.getElementById('lista-ticket-trovati'); container.innerHTML = ""; results.forEach(res => { const btn = document.createElement('button'); btn.className='ticket-btn'; btn.innerHTML=`<b>${res.tck||'Senza TCK'}</b> - ${res.cliente||'Senza Cliente'}<br><span style="font-size:10px; color:#666;">${res.problema||''}</span>`; btn.onclick=() => { document.getElementById('select-ticket-overlay').style.display='none'; applicaDatiCalendario(res); }; container.appendChild(btn); }); document.getElementById('select-ticket-overlay').style.display='flex'; }
    function applicaDatiCalendario(data) {
        document.getElementById('n_rapporto_input').value  = data.tck || "";
        document.getElementById('macchina_input').value    = (data.matricola || "").toUpperCase();
        document.getElementById('cliente_input').value     = (data.cliente   || "").toUpperCase();
        document.getElementById('indirizzo_input').value   = (data.indirizzo || "").toUpperCase();
        document.getElementById('email_input').value       = data.email ? data.email.toLowerCase() : "";
        const resp = document.getElementsByName('nome_responsabile')[0];
        if(data.contatto) resp.value = data.contatto.toUpperCase();
        else if(data.email) resp.value = data.email.split('@')[0].replace(/\./g,' ').toUpperCase();
        const container = document.getElementById('lista-tecnici-inputs');
        while(container.children.length > 1) container.removeChild(container.lastChild);
        if(data.tecnici && data.tecnici.length > 0) {
            document.getElementsByName('tecnico_1')[0].value = data.tecnici[0].toUpperCase();
            if(document.getElementsByName('tec_1')[0]) document.getElementsByName('tec_1')[0].value = data.tecnici[0].toUpperCase();
            for(let i=1; i<data.tecnici.length; i++) aggiungiRigaTecnico(data.tecnici[i].toUpperCase(), true);
            document.querySelectorAll('#wiz-tec-grid .tec-btn').forEach(btn => {
                btn.classList.toggle('sel', data.tecnici.map(t=>t.toUpperCase()).includes(btn.textContent.trim()));
            });
            // Aggiorna anche i tecnici presenti nella prima giornata se esiste
            if (wizGiornate.length > 0) {
                wizGiornate[0].tecniciPresenti = [...wizGetTuttiTecnici()];
            }
        }
        // Sincronizza campi wizard base
        if(document.getElementById('w_ticket'))   document.getElementById('w_ticket').value   = data.tck || "";
        if(document.getElementById('w_cliente'))   document.getElementById('w_cliente').value   = (data.cliente||"").toUpperCase();
        if(document.getElementById('w_indirizzo')) document.getElementById('w_indirizzo').value = (data.indirizzo||"").toUpperCase();
        if(document.getElementById('w_matricola')) document.getElementById('w_matricola').value = (data.matricola||"").toUpperCase();
        if(document.getElementById('w_email') && data.email) document.getElementById('w_email').value = data.email.toLowerCase();

        // Precompila PROBLEMA RISCONTRATO dal calendario (step 4)
        const problema = (data.problema || '').toUpperCase();
        if(document.getElementById('w_problema')) document.getElementById('w_problema').value = problema;
        // Svuota LAVORO ESEGUITO — lo deve compilare il tecnico
        if(document.getElementById('w_lavoro')) document.getElementById('w_lavoro').value = '';
        wizContaChar();
        // Aggiorna il testo unificato nel campo A4
        wizAggiornaTesto();

        // Reset revisione A4 (nuovo dato importato → va ricontrollato)
        const okCb = document.getElementById('w_revisione_ok');
        if (okCb) okCb.checked = false;
        const conf = document.getElementById('ws4c-conferma');
        if (conf) conf.style.display = 'none';

        // ── MATERIALI ──────────────────────────────────────────
        const hasMat = data.materiali && data.materiali.length > 0;
        wizAggiornaStepper(hasMat);
        matExtra = [];
        if (hasMat) {
            matBuildLista(data.materiali);
        } else {
            matDaCalendario = [];
            const c = document.getElementById('mat-lista-calendario');
            if (c) c.innerHTML = '';
            const el = document.getElementById('mat-extra-list');
            if (el) el.innerHTML = '';
        }

        document.getElementById('id_univoco_input').value = "";
        generaIdUnivoco(); saveDraft();
    }
