<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" id="viewport-meta">
    <title>TMC Service - App Rapporti A4</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        :root { --tmc-blue: #0054a6; --tmc-light-blue: #f0f7ff; --tmc-dark: #222; }
        body { font-family: 'Helvetica Neue', Arial, sans-serif; margin: 0; padding: 0; background: #525659; color: var(--tmc-dark); }

        /* ── TOGGLE MODALITÀ ── */
        .mode-toggle-bar {
            display: flex; align-items: center; justify-content: center;
            gap: 0; max-width: 210mm; margin: 12px auto; padding: 0 10px;
        }
        .mode-toggle-bar button {
            flex: 1; padding: 10px 8px; border: 1.5px solid var(--tmc-blue);
            font-size: 13px; font-weight: bold; cursor: pointer;
            transition: background .15s, color .15s;
        }
        .mode-toggle-bar button:first-child { border-radius: 6px 0 0 6px; border-right: none; }
        .mode-toggle-bar button:last-child  { border-radius: 0 6px 6px 0; }
        .mode-toggle-bar button.active      { background: var(--tmc-blue); color: white; }
        .mode-toggle-bar button:not(.active){ background: white; color: var(--tmc-blue); }

        /* ── WIZARD ── */
        #wizard-view {
            display: none; max-width: 480px; margin: 0 auto;
            background: white; min-height: 100vh; padding-bottom: 2rem;
        }
        .wiz-prog-wrap { padding: 1rem 1rem 0; background: white; position: sticky; top: 0; z-index: 10; border-bottom: 1px solid #eee; }
        .wiz-prog-bg   { height: 7px; background: #e0e8f5; border-radius: 4px; overflow: hidden; }
        .wiz-prog-fill { height: 100%; background: var(--tmc-blue); border-radius: 4px; transition: width .4s ease; }
        .wiz-step-label{ display: flex; justify-content: space-between; font-size: 11px; color: #888; margin: 5px 0 8px; }
        .wiz-screen    { padding: 1.1rem 1rem; display: none; }
        .wiz-screen.active { display: block; }
        .wiz-head      { margin-bottom: 1.1rem; }
        .wiz-pill      { display: inline-block; font-size: 11px; font-weight: bold; background: #e6f1fb; color: #0c447c; border-radius: 20px; padding: 3px 10px; margin-bottom: 6px; }
        .wiz-head h2   { font-size: 19px; font-weight: bold; color: var(--tmc-dark); margin: 0 0 4px; }
        .wiz-head p    { font-size: 13px; color: #666; margin: 0; }
        .wiz-field     { margin-bottom: .9rem; }
        .wiz-field label { display: block; font-size: 11px; font-weight: bold; color: var(--tmc-blue); text-transform: uppercase; margin-bottom: 3px; }
        .wiz-field input,.wiz-field select,.wiz-field textarea {
            width: 100%; padding: 10px 12px;
            border: 1px solid #cce0f5; border-radius: 5px;
            font-size: 15px; background: white; color: var(--tmc-dark);
            box-sizing: border-box;
        }
        .wiz-field textarea { resize: none; line-height: 1.5; font-family: inherit; }
        .wiz-field input:focus,.wiz-field select:focus,.wiz-field textarea:focus {
            outline: none; border-color: var(--tmc-blue); box-shadow: 0 0 0 2px rgba(0,84,166,.1);
        }
        .wiz-hint { font-size: 11px; color: #888; margin-top: 3px; }
        .wiz-sync-btn {
            width: 100%; padding: 10px; border: 1.5px dashed #b0c8e8;
            border-radius: 5px; font-size: 13px; font-weight: bold;
            background: #f0f7ff; color: var(--tmc-blue); cursor: pointer; margin-top: 4px;
        }
        .tec-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 8px; margin-top: 4px; }
        .tec-btn {
            padding: 11px 6px; border: 1px solid #cce0f5; border-radius: 5px;
            font-size: 12px; font-weight: bold; background: white;
            color: var(--tmc-dark); cursor: pointer; text-align: center;
            transition: background .12s, border-color .12s;
        }
        .tec-btn.sel { background: #e6f1fb; border-color: var(--tmc-blue); color: #0c447c; }
        .orari-group { margin-bottom: 10px; }
        .orari-group-label { font-size: 11px; font-weight: bold; color: #666; text-transform: uppercase; margin-bottom: 4px; }
        .orari-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .orari-sub { font-size: 10px; color: #aaa; margin-bottom: 2px; }
        .pch-row { display: flex; gap: 16px; margin-top: 4px; }
        .pch-item { display: flex; align-items: center; gap: 7px; font-size: 14px; font-weight: bold; color: var(--tmc-blue); }
        .pch-item input { width: 22px; height: 22px; cursor: pointer; }
        .tmpl-card {
            background: #f8fbff; border: 1px solid #cce0f5; border-radius: 6px;
            padding: .7rem .9rem; margin-bottom: 8px; cursor: pointer;
        }
        .tmpl-card:active { background: #e6f1fb; }
        .tmpl-card strong { font-size: 13px; color: var(--tmc-blue); display: block; margin-bottom: 2px; }
        .tmpl-card p { font-size: 12px; color: #666; margin: 0; }
        .char-bar { font-size: 11px; text-align: right; margin-top: 3px; color: #aaa; }
        .char-bar.ok   { color: #3B6D11; font-weight: bold; }
        .char-bar.warn { color: #BA7517; }
        .recap-row { background: #f8fbff; border-radius: 5px; padding: .6rem .9rem; margin-bottom: 7px; }
        .recap-row .rl { font-size: 10px; text-transform: uppercase; color: #888; margin-bottom: 2px; }
        .recap-row .rv { font-size: 14px; font-weight: bold; color: var(--tmc-dark); }
        .recap-row .rv.miss { color: #A32D2D; }
        .sig-area {
            border: 2px dashed #cce0f5; border-radius: 6px; height: 120px;
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; gap: 6px; cursor: pointer;
            background: #fafafa; font-size: 13px; color: #aaa; font-weight: bold;
        }
        .sig-area.signed { border-color: #3B6D11; background: #eaf3de; color: #3B6D11; }
        .sig-area svg { width: 32px; height: 32px; }
        .wiz-alert {
            background: #fff0f0; border: 1px solid #f7c1c1; border-radius: 5px;
            padding: .65rem .9rem; margin-bottom: .8rem; font-size: 13px; color: #A32D2D;
            display: none;
        }
        .wiz-actions { display: flex; gap: 8px; padding: 1rem; border-top: 1px solid #eee; background: white; position: sticky; bottom: 0; }
        .wiz-btn-back {
            flex: 1; padding: 13px; border: 1.5px solid #cce0f5; border-radius: 6px;
            background: white; font-size: 14px; font-weight: bold;
            color: #666; cursor: pointer;
        }
        .wiz-btn-next {
            flex: 2; padding: 13px; border: none; border-radius: 6px;
            background: var(--tmc-blue); color: white;
            font-size: 14px; font-weight: bold; cursor: pointer;
        }
        .wiz-btn-send {
            flex: 2; padding: 13px; border: none; border-radius: 6px;
            background: #25D366; color: white;
            font-size: 14px; font-weight: bold; cursor: pointer;
        }
        .wiz-divider { height: 1px; background: #eee; margin: .8rem 0; }

        .mat-item { display:flex; align-items:center; gap:10px; padding:10px 0; border-bottom:1px solid #f0f0f0; }
        .mat-item:last-child { border-bottom:none; }
        .mat-check { width:24px; height:24px; cursor:pointer; flex-shrink:0; accent-color:var(--tmc-blue); }
        .mat-testo { flex:1; font-size:14px; color:var(--tmc-dark); line-height:1.3; }
        .mat-testo.usato { font-weight:bold; color:var(--tmc-blue); }
        .mat-qta { width:54px; padding:6px 4px; border:1px solid #cce0f5; border-radius:5px; font-size:15px; font-weight:bold; color:var(--tmc-blue); text-align:center; background:white; }
        .mat-qta:disabled { background:#f5f5f5; color:#bbb; border-color:#eee; }
        .mat-badge-lista { display:inline-block; font-size:10px; background:#e6f1fb; color:#0c447c; border-radius:10px; padding:1px 7px; margin-left:4px; }
        .mat-aggiungi { display:flex; gap:8px; margin-top:12px; align-items:center; }
        .mat-aggiungi input { flex:1; padding:10px 12px; border:1px solid #cce0f5; border-radius:5px; font-size:14px; background:white; }
        .mat-aggiungi-btn { padding:10px 14px; background:var(--tmc-blue); color:white; border:none; border-radius:5px; font-size:20px; font-weight:bold; cursor:pointer; flex-shrink:0; }
        .mat-extra-list { margin-top:6px; }
        .mat-extra-item { display:flex; align-items:center; gap:8px; padding:7px 0; border-bottom:1px solid #f5f5f5; }
        .mat-extra-item input.mat-extra-testo { flex:1; border:none; border-bottom:1px solid #cce0f5; font-size:14px; padding:4px 2px; background:transparent; }
        .mat-extra-del { background:none; border:none; color:#ff4444; font-size:18px; font-weight:bold; cursor:pointer; padding:0 4px; }
        .page-a4 { background: white; width: 210mm; min-height: 297mm; margin: 10px auto; padding: 1mm 8mm 2mm 8mm; box-sizing: border-box; box-shadow: 0 0 10px rgba(0,0,0,0.5); display: flex; flex-direction: column; position: relative; }
        @media screen and (max-width: 210mm) { body { background: white; } .page-a4 { width: 100%; margin: 0; padding: 10px; box-shadow: none; } }
        body.pdf-mode { background: white !important; }
        body.pdf-mode .page-a4 { width: 210mm !important; height: auto !important; min-height: auto !important; max-width: none !important; margin: 0 !important; padding: 1mm 8mm !important; box-shadow: none !important; border: none !important; transform: none !important; overflow: visible !important; }
        body.pdf-mode .no-print { display: none !important; }
        .banner-static { width: 100%; display: block; }
        .main-title-container { display: flex; justify-content: space-between; align-items: center; color: var(--tmc-blue); font-weight: bold; border-top: 2px solid var(--tmc-blue); border-bottom: 2px solid var(--tmc-blue); padding: 4px; margin: 5px 0; }
        .tipo-box { border: 2px solid var(--tmc-blue); padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 10px; }
        .tipo-box.active { background: var(--tmc-blue); color: white; }
        .card { border: 1px solid var(--tmc-blue); padding: 6px 10px; margin-bottom: 6px; border-radius: 5px; position: relative; }
        .grid-header { display: grid; grid-template-columns: 1fr 1.5fr; gap: 20px; }
        .input-field label { font-size: 8px; font-weight: bold; color: var(--tmc-blue); display: block; text-transform: uppercase; margin-bottom: 2px; }
        input, textarea, select { border: none; border-bottom: 1px solid #cce0f5; padding: 4px 0; font-size: 12px; outline: none; width: 100%; background: transparent; }
        .caps { text-transform: uppercase; }
        .tecnico-combo { position: relative; width: 100%; height: 25px; }
        .tecnico-input-main { position: absolute; top: 0; left: 0; width: calc(100% - 25px); border-bottom: 1px solid #cce0f5; z-index: 2; background: white; text-transform: uppercase; }
        .tecnico-select-bg { width: 100%; position: relative; z-index: 1; }
        table { width: 100%; border-collapse: collapse; border: 1px solid var(--tmc-blue); margin-top: 5px; }
        th { background: var(--tmc-light-blue); font-size: 7px; border: 1px solid var(--tmc-blue); padding: 5px 2px; color: var(--tmc-blue); }
        td { border: 1px solid var(--tmc-blue); padding: 3px 1px; text-align: center; }
        .time-select { font-size: 11px; font-weight: bold; color: var(--tmc-blue); background: transparent; border: 1px solid transparent; width: 100%; height: 26px; border-radius: 3px; text-align: center; margin: 0; padding: 0; outline: none; }
        .pch-row-a4 { display: flex; justify-content: center; gap: 3px; font-size: 9px; font-weight: bold; align-items: center; }
        .pch-row-a4 input { width: auto; margin: 0; }
        .bottom-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 15px; margin-top: auto; padding-top: 5px; }
        .dotted-line { border-bottom: 1px dotted var(--tmc-blue); height: 18px; margin-bottom: 5px; }
        .sig-preview { border: 2px dashed var(--tmc-blue); width: 100%; height: 120px; background: #f9f9f9; display: flex; align-items: center; justify-content: center; cursor: pointer; padding: 5px; box-sizing: border-box; }
        .sig-preview img { width: 100%; height: 100%; object-fit: contain; }
        #signature-overlay { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:white; z-index: 9999; flex-direction: column; }
        #canvas-fullscreen { flex-grow: 1; border: 3px solid var(--tmc-blue); margin: 15px; background: #fafafa; touch-action: none; }
        .footer-static { width: 66%; display: block; margin: 5px auto; }
        .no-print { display: flex; flex-wrap: wrap; gap: 10px; padding: 15px; max-width: 210mm; margin: 0 auto; justify-content: center; }
        .btn { flex: 1; min-width: 90px; padding: 12px 5px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; color: white; font-size: 11px; text-align: center; }
        .btn-blue { background: var(--tmc-blue); } .btn-green { background: #25D366; } .btn-orange { background: #ff9800; } .btn-dark { background: #444; }
        .btn-sync { position: absolute; right: 10px; top: 10px; font-size: 20px; background: none; border: none; cursor: pointer; z-index: 10; }
        @media print { body { background: white; } .page-a4 { margin: 0; border: none; box-shadow: none; width: 210mm; height: auto; min-height: 297mm; padding: 2mm 8mm; } .no-print, .btn-sync, .mode-toggle-bar { display: none !important; } .card, tr, .bottom-grid, .main-title-container { page-break-inside: avoid; break-inside: avoid; } }
        #loading-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 10000; color: white; flex-direction: column; justify-content: center; align-items: center; font-family: sans-serif; font-weight: bold; text-align: center; padding: 20px;}
        .spinner { border: 6px solid #f3f3f3; border-top: 6px solid var(--tmc-blue); border-radius: 50%; width: 50px; height: 50px; animation: spin 1s linear infinite; margin-bottom: 20px; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .overlay-bg { display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(82, 86, 89, 0.95); z-index: 99999; flex-direction: column; justify-content: center; align-items: center; }
        .modal-box { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.5); text-align: center; color: var(--tmc-dark); width: 85%; max-width: 450px; }
        .modal-box input { border: 2px solid var(--tmc-blue); padding: 12px; margin: 20px 0; width: calc(100% - 24px); font-size: 18px; text-align: center; border-radius: 5px; outline: none; }
        .modal-box button { background: var(--tmc-blue); color: white; border: none; padding: 15px; font-size: 16px; border-radius: 5px; cursor: pointer; width: 100%; font-weight: bold; }
        #drafts-overlay { z-index: 99998; }
        .draft-item { display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #ddd; padding:10px 0; text-align:left; gap: 5px;}
        .modal-time-label { display:block; font-size:11px; font-weight:bold; color:var(--tmc-blue); margin-bottom:3px; }
        .modal-time-group { display:grid; grid-template-columns: 1fr 1fr; gap:15px; margin-bottom:15px; background:#f9f9f9; padding:10px; border-radius:5px; border:1px solid #eee; }
        .modal-time-select { width:100%; padding:10px; font-size:16px; border:1px solid #ccc; border-radius:4px; outline:none; background:white; font-weight:bold; color:var(--tmc-blue); text-align:center; appearance: none; }
        .ticket-btn { background:#f0f7ff; color:var(--tmc-blue); border:1px solid var(--tmc-blue); padding:10px; text-align:left; border-radius:5px; margin-bottom:8px; width:100%; cursor:pointer; }
        .ticket-btn:hover { background:var(--tmc-blue); color:white; }
    </style>
</head>
<body>
    <!-- OVERLAY LOGIN -->
    <div id="login-overlay" class="overlay-bg">
        <div class="modal-box">
            <img src="static/intestazione.jpg" style="width: 100%; margin-bottom: 10px;">
            <h3 style="color:var(--tmc-blue); margin-bottom: 5px;">Accesso Riservato</h3>
            <p style="font-size: 12px; color: #666; margin-top: 0;">Inserisci la password aziendale</p>
            <input type="password" id="pin_input" placeholder="Password">
            <button id="btn-login" onclick="verificaLogin()">ACCEDI</button>
            <p id="login-error" style="color:red; font-size:13px; display:none; margin-top:15px; font-weight:bold;">Password errata. Riprova.</p>
        </div>
    </div>

    <!-- OVERLAY EMAIL TECNICO (prima volta) -->
    <div id="email-tecnico-overlay" class="overlay-bg" style="display:none;">
        <div class="modal-box" style="max-width:420px;">
            <img src="static/intestazione.jpg" style="width:100%; margin-bottom:12px;">
            <h3 style="color:var(--tmc-blue); margin:0 0 6px;">La tua email personale</h3>
            <p style="font-size:13px; color:#666; margin:0 0 4px;">Verrà usata per inviarti una <b>copia di conferma</b> ogni volta che invii un rapporto.</p>
            <p style="font-size:11px; color:#aaa; margin:0 0 16px;">Viene salvata solo su questo telefono e non verrà mai richiesta di nuovo.</p>
            <input type="email" id="email_tecnico_input"
                placeholder="tua@email.it"
                style="border:2px solid var(--tmc-blue); padding:14px; font-size:16px; text-align:center; border-radius:5px; width:calc(100% - 28px); outline:none; text-transform:none; margin-bottom:8px;">
            <p id="email-tecnico-err" style="color:red; font-size:12px; display:none; margin:0 0 8px;">Inserisci un indirizzo email valido.</p>
            <button onclick="salvaEmailTecnico()" style="width:100%; padding:14px; background:var(--tmc-blue); color:white; border:none; border-radius:5px; font-size:15px; font-weight:bold; cursor:pointer; margin-bottom:8px;">SALVA E CONTINUA</button>
            <button onclick="saltaEmailTecnico()" style="width:100%; padding:10px; background:transparent; color:#aaa; border:1px solid #ddd; border-radius:5px; font-size:12px; cursor:pointer;">Salta per ora (non riceverò conferme)</button>
        </div>
    </div>

    <!-- OVERLAY EMAIL -->
    <div id="email-editor-overlay" class="overlay-bg" style="display:none; padding: 20px; box-sizing: border-box; z-index: 99999;">
        <div style="background:white; width:100%; max-width: 450px; border-radius:8px; display:flex; flex-direction:column; overflow:hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.5);">
            <div style="padding:15px; background:var(--tmc-blue); color:white; text-align:center;"><b style="font-size:16px;">INSERISCI EMAIL CLIENTE</b></div>
            <div style="padding:25px;"><input type="email" id="modal_email_input" placeholder="nome.cognome@azienda.it" style="width:100%; padding:15px; font-size:18px; text-transform:none; border:2px solid var(--tmc-blue); border-radius:5px; box-sizing:border-box; outline:none; text-align:center;"></div>
            <div style="display:flex; gap:1px; background:#ddd;">
                <button onclick="chiudiEditorEmail(false)" style="flex:1; padding:15px; background:#eee; color:#333; border:none; font-weight:bold; cursor:pointer;">ANNULLA</button>
                <button onclick="chiudiEditorEmail(true)" style="flex:1; padding:15px; background:#25D366; color:white; border:none; font-weight:bold; cursor:pointer;">CONFERMA</button>
            </div>
        </div>
    </div>

    <!-- OVERLAY BOZZE -->
    <div id="drafts-overlay" class="overlay-bg" style="display:none;">
        <div class="modal-box" style="max-height: 85%; overflow-y: auto; padding: 15px;">
            <h3 style="color:var(--tmc-blue); margin-top:0;">Archivio Bozze</h3>
            <button onclick="salvaBozzaAttuale()" style="background:#ff9800; margin-bottom:15px; font-size:13px; padding:12px;">💾 SALVA RAPPORTO ATTUALE</button>
            <div style="background:#fff3e0; padding:10px; border-radius:5px; margin-bottom:15px; border:1px solid #ffcc80;">
                <h4 style="margin:0 0 10px 0; color:#e65100; font-size:12px; text-align:left;">📱 BOZZE SUL DISPOSITIVO (Offline)</h4>
                <div id="lista-bozze-locali"></div>
            </div>
            <div style="background:#e3f2fd; padding:10px; border-radius:5px; margin-bottom:15px; border:1px solid #90caf9;">
                <h4 style="margin:0 0 10px 0; color:#1565c0; font-size:12px; text-align:left;">☁️ BOZZE CONDIVISE (Cloud)</h4>
                <div id="lista-bozze-cloud"></div>
            </div>
            <button onclick="document.getElementById('drafts-overlay').style.display = 'none';" style="background:#444;">CHIUDI ARCHIVIO</button>
        </div>
    </div>

    <!-- OVERLAY SELEZIONE TICKET -->
    <div id="select-ticket-overlay" class="overlay-bg" style="display:none;">
        <div class="modal-box" style="max-height: 80%; overflow-y: auto; padding: 20px;">
            <h3 style="color:var(--tmc-blue); margin-top:0;">Seleziona Intervento</h3>
            <div id="lista-ticket-trovati" style="margin-bottom: 15px; display:flex; flex-direction:column;"></div>
            <button onclick="document.getElementById('select-ticket-overlay').style.display='none';" style="background:#444;">ANNULLA</button>
        </div>
    </div>

    <!-- OVERLAY TESTO -->
    <div id="text-editor-overlay" class="overlay-bg" style="display:none; padding: 20px; box-sizing: border-box; z-index: 99999;">
        <div style="background:white; width:100%; max-width: 600px; height:80%; border-radius:8px; display:flex; flex-direction:column; overflow:hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.5);">
            <div style="padding:15px; background:var(--tmc-blue); color:white; text-align:center;"><b style="font-size:16px;">PROBLEMA SEGNALATO / LAVORO ESEGUITO</b></div>
            <div style="background:#f0f7ff; padding:8px; text-align:center; border-bottom:1px solid #ddd;">
                <button onclick="inserisciSeparatoreTesto('editor_fullscreen')" style="background:#ff9800; color:white; border:none; padding:8px 15px; border-radius:4px; font-weight:bold; font-size:11px; cursor:pointer;">➖ INSERISCI RIGA "LAVORO ESEGUITO"</button>
            </div>
            <textarea id="editor_fullscreen" class="caps" style="flex:1; width:100%; border:none; padding:15px; font-size:16px; outline:none; resize:none; box-sizing:border-box;" placeholder="Scrivi qui tutti i dettagli..."></textarea>
            <div style="padding:15px; display:flex; gap:10px; background:#f9f9f9; border-top:1px solid #ddd;">
