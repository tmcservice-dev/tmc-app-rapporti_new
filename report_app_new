    <script>
    const APP_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwflYcjnY-wzmJBmf8LlRh00vDx-L4ckMISLP27b6Upz7x6eK-1HJeb4EAywFI2R2RxlA/exec";
    const FRASE_SICUREZZA = "";
    const RIT_LABEL = "+ RIT.";

    // ═══════════════════════════════════════════════
    // TOGGLE MODALITÀ
    // ═══════════════════════════════════════════════
    function setMode(mode) {
        const isWiz = mode === 'wizard';
        document.getElementById('wizard-view').style.display = isWiz ? 'block' : 'none';
        document.getElementById('a4-view').style.display     = isWiz ? 'none'  : 'block';
        document.getElementById('btn-mode-wiz').className    = isWiz ? 'active' : '';
        document.getElementById('btn-mode-a4').className     = isWiz ? '' : 'active';
        // Quando si passa al modulo A4, aggiorna tutti i totali
        if (!isWiz) calc();
        localStorage.setItem('tmc_mode', mode);
    }

    // ═══════════════════════════════════════════════
    // WIZARD — stato
    // ═══════════════════════════════════════════════
    let wizCur = 1;
    // wizSteps: sequenza step attivi. '4b'=materiali e '4c'=anteprima A4 sono condizionali
    let wizSteps = [1, 2, 3, 4, '4c', 5];
    const WIZ_NAMES_MAP = {
        1: 'Intervento', 2: 'Tecnici', 3: 'Orari',
        4: 'Descrizione', '4b': 'Materiali', '4c': 'Anteprima A4', 5: 'Firma e invio'
    };

    // Materiali dal calendario
    let matDaCalendario = [];
    let matExtra = [];

    // Orari per tecnico: { nomeTecnico: {va1,va2,lm1,lm2,lp1,lp2,vr1,vr2,p,c,h} }
    // Orari multi-giornata (vedi STEP 3)
    let wizGiornate = [];      // [{data, tecniciPresenti:[], orari:{nome:{...}}}]
    let wizGiornoIdx = 0;
    let wizTabOrariAttiva = 0;

    // Tecnico ricercato in step 1 (modalità per tecnico)
    let s1TecnicoSelezionato = '';
    let s1Modalita = 'ticket';

    function wizTotaleStep() { return wizSteps.length; }
    function wizPosizione()  { return wizSteps.indexOf(wizCur) + 1; }

    function wizUpdateProgress() {
        const pos = wizPosizione();
        const tot = wizTotaleStep();
        document.getElementById('wiz-pbar').style.width = (pos / tot * 100) + '%';
        document.getElementById('wiz-step-lbl').textContent  = 'Step ' + pos + ' di ' + tot;
        document.getElementById('wiz-step-name').textContent = WIZ_NAMES_MAP[wizCur] || '';
        document.getElementById('wiz-btn-back').style.display = pos > 1 ? 'block' : 'none';
        const btnNext = document.getElementById('wiz-btn-next');
        btnNext.style.display = wizCur !== 5 ? 'block' : 'none';
        // Aggiorna pill dinamiche
        ['4b','4c'].forEach(k => {
            const el = document.getElementById('ws'+k+'-pill');
            if (el) el.textContent = 'Step ' + (wizSteps.indexOf(k)+1) + ' — ' + WIZ_NAMES_MAP[k];
        });
    }

    function wizShowScreen(step) {
        document.querySelectorAll('.wiz-screen').forEach(s => {
            s.classList.remove('active');
            s.style.display = ''; // rimuove qualsiasi override inline, lascia decidere il CSS
        });
        const el = document.getElementById('ws' + step);
        if (el) {
            el.style.display = ''; // CSS .wiz-screen.active = display:block si occupa del resto
            el.classList.add('active');
        }
        wizCur = step;
        wizUpdateProgress();
        if (step === 3)    wizRenderGiorno();
        if (step === 5)    { wizPopolaRiepilogo(); wizCheckEmail(); }
        window.scrollTo(0, 0);
    }

    function wizGoNext() {
        let valid = true;
        const errEl = document.getElementById('werr' + wizCur);
        if (errEl) errEl.style.display = 'none';
        if (wizCur === 1)    { valid = wizVal1();   if (!valid) document.getElementById('werr1').style.display = 'block'; }
        if (wizCur === 2)    { valid = wizVal2();   if (!valid) document.getElementById('werr2').style.display = 'block'; wizRenderGiorno(); }
        if (wizCur === 3)    { valid = wizVal3();   if (!valid) document.getElementById('werr3').style.display = 'block'; else wizSyncAllOrariA4(); }
        if (wizCur === 4)    { valid = wizVal4();   if (!valid) document.getElementById('werr4').style.display = 'block'; }
        if (wizCur === '4c') { valid = wizVal4c();  if (!valid) document.getElementById('werr4c').style.display = 'block'; }
        if (wizCur === '4b') {
            // Sincronizza sempre i materiali verso A4, poi procedi
            matSyncA4();
            // Se nulla è selezionato, mostra avviso informativo ma non blocca
            const hasSel = [...document.querySelectorAll('.mat-check')].some(cb => cb.checked) || matExtra.length > 0;
            if (!hasSel) {
                document.getElementById('werr4b').style.display = 'block';
                // Avviso non bloccante: dopo 2 secondi procede da solo, oppure l'utente clicca ancora Avanti
                if (!wizCur4bAvvisato) {
                    wizCur4bAvvisato = true;
                    return; // Prima pressione: mostra avviso
                }
                // Seconda pressione: procede comunque
            }
            wizCur4bAvvisato = false;
            document.getElementById('werr4b').style.display = 'none';
        }
        if (!valid) return;
        const idx = wizSteps.indexOf(wizCur);
        if (idx < wizSteps.length - 1) wizShowScreen(wizSteps[idx + 1]);
    }

    function wizGoBack() {
        hideAllWizErrors();
        const idx = wizSteps.indexOf(wizCur);
        if (idx > 0) wizShowScreen(wizSteps[idx - 1]);
    }

    function hideAllWizErrors() {
        [1,2,3,4,'4b','4c',5].forEach(i => {
            const el = document.getElementById('werr' + i);
            if (el) el.style.display = 'none';
        });
    }

    // Aggiorna stepper: inserisce/rimuove '4b' (materiali) dopo 4, prima di '4c'
    function wizAggiornaStepper(hasMateriali) {
        wizSteps = wizSteps.filter(s => s !== '4b');
        if (hasMateriali) {
            const idx4 = wizSteps.indexOf(4);
            wizSteps.splice(idx4 + 1, 0, '4b');
        }
        wizUpdateProgress();
    }

    // ── STEP 1: tab ticket / tecnico ─────────────────────────
    function s1SetTab(modo) {
        s1Modalita = modo;
        document.getElementById('s1-panel-ticket').style.display  = modo === 'ticket'  ? 'block' : 'none';
        document.getElementById('s1-panel-tecnico').style.display = modo === 'tecnico' ? 'block' : 'none';
        document.getElementById('s1-tab-tck').style.background  = modo === 'ticket'  ? 'var(--tmc-blue)' : 'white';
        document.getElementById('s1-tab-tck').style.color       = modo === 'ticket'  ? 'white' : 'var(--tmc-blue)';
        document.getElementById('s1-tab-tec').style.background  = modo === 'tecnico' ? 'var(--tmc-blue)' : 'white';
        document.getElementById('s1-tab-tec').style.color       = modo === 'tecnico' ? 'white' : 'var(--tmc-blue)';
    }

    function s1SelTec(btn) {
        document.querySelectorAll('#s1-tec-grid .tec-btn').forEach(b => b.classList.remove('sel'));
        btn.classList.add('sel');
        s1TecnicoSelezionato = btn.textContent.trim();
        document.getElementById('s1-tec-label').textContent = s1TecnicoSelezionato;
        document.getElementById('s1-tec-libero').value = '';
        document.querySelectorAll('#wiz-tec-grid .tec-btn').forEach(b => {
            if (b.textContent.trim() === s1TecnicoSelezionato) b.classList.add('sel');
        });
    }

    function s1SelTecLibero() {
        const nome = document.getElementById('s1-tec-libero').value.trim().toUpperCase();
        if (!nome) return;
        // Deseleziona griglia
        document.querySelectorAll('#s1-tec-grid .tec-btn').forEach(b => b.classList.remove('sel'));
        s1TecnicoSelezionato = nome;
        document.getElementById('s1-tec-label').textContent = nome;
        // Aggiunge o seleziona nel wizard step 2 come tecnico extra
        wizAgiungiTecNomeEsterno(nome);
    }

    // ── VALIDAZIONI ───────────────────────────────────────────
    function wizVal1() {
        document.getElementById('werr1').style.display = 'none';
        return document.getElementById('w_ticket').value.trim() &&
               document.getElementById('w_cliente').value.trim();
    }
    function wizVal2() {
        document.getElementById('werr2').style.display = 'none';
        return wizGetTuttiTecnici().length > 0;
    }
    function wizVal3() {
        document.getElementById('werr3').style.display = 'none';
        // Salva orari correnti prima di validare
        wizSalvaOrariTabCorrente();
        // Almeno una giornata deve avere un tecnico con orario di lavoro
        if (!wizGiornate.length) return false;
        for (const g of wizGiornate) {
            for (const nome of g.tecniciPresenti) {
                const o = g.orari[nome] || {};
                if ((o.lm1 && o.lm2) || (o.lp1 && o.lp2)) return true;
            }
        }
        return false;
    }
    function wizVal4() {
        document.getElementById('werr4').style.display = 'none';
        const lavoro = (document.getElementById('w_lavoro')?.value || '').trim();
        return lavoro.length >= 10;
    }
    function wizVal4c() {
        document.getElementById('werr4c').style.display = 'none';
        return document.getElementById('w_revisione_ok')?.checked;
    }

    // ── STEP 3: ORARI MULTI-GIORNO ───────────────────────────
    const CAMPI_ORARI = ['va1','va2','lm1','lm2','lp1','lp2','vr1','vr2'];
    // wizGiornate, wizGiornoIdx, wizTabOrariAttiva sono dichiarate in cima

    function wizGiornoCorrente() { return wizGiornate[wizGiornoIdx] || null; }

    function wizInizializzaPrimaGiornata() {
        if (wizGiornate.length === 0) {
            const oggi = new Date().toISOString().split('T')[0];
            wizGiornate.push({
                data: oggi,
                tecniciPresenti: [...wizGetTuttiTecnici()],
                orari: {}
            });
            wizGiornoIdx = 0;
        }
    }

    function wizAggiungiGiorno() {
        wizSalvaOrariTabCorrente();
        // Default: stessa data + 1 giorno della precedente, stessi tecnici
        let dataDefault = new Date().toISOString().split('T')[0];
        if (wizGiornate.length > 0) {
            const ultima = wizGiornate[wizGiornate.length - 1].data;
            if (ultima) {
                const d = new Date(ultima + 'T12:00');
                d.setDate(d.getDate() + 1);
                dataDefault = d.toISOString().split('T')[0];
            }
        }
        wizGiornate.push({
            data: dataDefault,
            tecniciPresenti: [...wizGetTuttiTecnici()],
            orari: {}
        });
        wizGiornoIdx = wizGiornate.length - 1;
        wizTabOrariAttiva = 0;
        wizRenderGiorno();
    }

    function wizEliminaGiorno() {
        if (wizGiornate.length <= 1) { alert('Deve esserci almeno una giornata.'); return; }
        if (!confirm('Eliminare questa giornata? Tutti gli orari inseriti andranno persi.')) return;
        wizGiornate.splice(wizGiornoIdx, 1);
        if (wizGiornoIdx >= wizGiornate.length) wizGiornoIdx = wizGiornate.length - 1;
        wizTabOrariAttiva = 0;
        wizRenderGiorno();
    }

    function wizCambiaGiorno(delta) {
        wizSalvaOrariTabCorrente();
        const nuovo = wizGiornoIdx + delta;
        if (nuovo < 0 || nuovo >= wizGiornate.length) return;
        wizGiornoIdx = nuovo;
        wizTabOrariAttiva = 0;
        wizRenderGiorno();
    }

    function wizSalvaDataGiorno() {
        const g = wizGiornoCorrente();
        if (!g) return;
        g.data = document.getElementById('wiz-giorno-data').value;
        // Aggiorna label
        const lbl = document.getElementById('wiz-giorno-label');
        lbl.textContent = g.data
            ? new Date(g.data + 'T12:00').toLocaleDateString('it-IT', {weekday:'long',day:'2-digit',month:'long',year:'numeric'})
            : 'Data non impostata';
    }

    function wizToggleTecGiorno(nome) {
        const g = wizGiornoCorrente();
        if (!g) return;
        wizSalvaOrariTabCorrente();
        const idx = g.tecniciPresenti.indexOf(nome);
        if (idx === -1) g.tecniciPresenti.push(nome);
        else g.tecniciPresenti.splice(idx, 1);
        if (wizTabOrariAttiva >= g.tecniciPresenti.length) wizTabOrariAttiva = 0;
        wizRenderGiorno();
    }

    function wizRenderGiorno() {
        wizInizializzaPrimaGiornata();
        const g = wizGiornoCorrente();
        if (!g) return;

        // Header navigazione giornata
        document.getElementById('wiz-giorno-counter').textContent = `Giornata ${wizGiornoIdx + 1} di ${wizGiornate.length}`;
        document.getElementById('wiz-giorno-data').value = g.data || '';
        document.getElementById('wiz-giorno-label').textContent = g.data
            ? new Date(g.data + 'T12:00').toLocaleDateString('it-IT', {weekday:'long',day:'2-digit',month:'long',year:'numeric'})
            : 'Data non impostata';
        document.getElementById('wiz-giorno-prev').disabled = wizGiornoIdx === 0;
        document.getElementById('wiz-giorno-next').disabled = wizGiornoIdx === wizGiornate.length - 1;
        document.getElementById('wiz-giorno-prev').style.opacity = wizGiornoIdx === 0 ? '0.4' : '1';
        document.getElementById('wiz-giorno-next').style.opacity = wizGiornoIdx === wizGiornate.length - 1 ? '0.4' : '1';
        document.getElementById('wiz-giorno-elimina').style.display = wizGiornate.length > 1 ? 'block' : 'none';

        // Chip tecnici presenti
        const chipsEl = document.getElementById('wiz-giorno-tecnici-chips');
        const tuttiTecnici = wizGetTuttiTecnici();
        chipsEl.innerHTML = '';
        if (tuttiTecnici.length === 0) {
            chipsEl.innerHTML = '<span style="font-size:12px; color:#a32d2d;">⚠️ Torna allo Step 2 per selezionare almeno un tecnico.</span>';
        } else {
            tuttiTecnici.forEach(nome => {
                const presente = g.tecniciPresenti.includes(nome);
                const chip = document.createElement('button');
                chip.textContent = (presente ? '✓ ' : '+ ') + nome;
                chip.onclick = () => wizToggleTecGiorno(nome);
                chip.style.cssText = `padding:6px 11px; border:1px solid ${presente ? 'var(--tmc-blue)' : '#ccc'}; background:${presente ? 'var(--tmc-blue)' : 'white'}; color:${presente ? 'white' : '#888'}; border-radius:14px; font-size:11px; font-weight:bold; cursor:pointer;`;
                chipsEl.appendChild(chip);
            });
        }

        // Render tab tecnici e panel orari
        const tabBar   = document.getElementById('wiz-orari-tabs');
        const panelsEl = document.getElementById('wiz-orari-panels');
        const copiaBtn = document.getElementById('wiz-copia-tutti-btn');
        const presenti = g.tecniciPresenti;

        tabBar.innerHTML = '';
        panelsEl.innerHTML = '';

        if (presenti.length === 0) {
            panelsEl.innerHTML = '<div style="padding:20px; text-align:center; color:#888; font-size:13px;">Nessun tecnico presente in questa giornata.<br>Aggiungi un tecnico dai chip qui sopra.</div>';
            copiaBtn.style.display = 'none';
            return;
        }

        // Inizializza orari per tecnici nuovi
        presenti.forEach(n => { if (!g.orari[n]) g.orari[n] = {}; });

        if (wizTabOrariAttiva >= presenti.length) wizTabOrariAttiva = 0;

        // Tabs tecnici
        presenti.forEach((nome, idx) => {
            const btn = document.createElement('button');
            btn.textContent = nome.split(' ')[0];
            btn.style.cssText = `flex:1; padding:9px 6px; border:none; border-bottom:${idx===wizTabOrariAttiva?'3px solid var(--tmc-blue)':'3px solid transparent'}; font-size:12px; font-weight:bold; background:${idx===wizTabOrariAttiva?'#f0f7ff':'white'}; color:${idx===wizTabOrariAttiva?'var(--tmc-blue)':'#888'}; cursor:pointer; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;`;
            btn.onclick = () => { wizSalvaOrariTabCorrente(); wizTabOrariAttiva = idx; wizRenderGiorno(); };
            tabBar.appendChild(btn);
        });

        // Panel tecnico attivo
        const nomeTecnico = presenti[wizTabOrariAttiva];
        const o = g.orari[nomeTecnico] || {};
        panelsEl.innerHTML = `
        <div style="padding:10px 0;">
            <div style="font-size:11px; color:#888; margin-bottom:10px; padding:6px 10px; background:#f8fbff; border-radius:5px; text-align:center;">
                <b style="color:var(--tmc-blue);">${nomeTecnico}</b>
            </div>
            ${renderOrariGroup('Viaggio andata',   'va1', 'va2', o)}
            ${renderOrariGroup('Lavoro mattina',   'lm1', 'lm2', o)}
            ${renderOrariGroup('Lavoro pomeriggio','lp1', 'lp2', o)}
            ${renderOrariGroup('Viaggio ritorno',  'vr1', 'vr2', o)}
            <div class="wiz-field" style="margin-top:8px;">
                <label>Pasti e pernottamento</label>
                <div class="pch-row">
                    <label class="pch-item"><input type="checkbox" id="wt_p" ${o.p?'checked':''} onchange="wizSalvaOrariTabCorrente()"> Pranzo</label>
                    <label class="pch-item"><input type="checkbox" id="wt_c" ${o.c?'checked':''} onchange="wizSalvaOrariTabCorrente()"> Cena</label>
                    <label class="pch-item"><input type="checkbox" id="wt_h" ${o.h?'checked':''} onchange="wizSalvaOrariTabCorrente()"> Hotel</label>
                </div>
            </div>
        </div>`;

        copiaBtn.style.display = presenti.length > 1 ? 'block' : 'none';
    }

    function renderOrariGroup(label, id1, id2, o) {
        return `<div class="orari-group">
            <div class="orari-group-label">${label}</div>
            <div class="orari-row">
                <div><div class="orari-sub">Da</div><input type="time" id="wt_${id1}" value="${o[id1]||''}" oninput="wizSalvaOrariTabCorrente()"></div>
                <div><div class="orari-sub">A</div><input type="time" id="wt_${id2}" value="${o[id2]||''}" oninput="wizSalvaOrariTabCorrente()"></div>
            </div>
        </div>`;
    }

    function wizSalvaOrariTabCorrente() {
        const g = wizGiornoCorrente();
        if (!g || !g.tecniciPresenti.length) return;
        const nome = g.tecniciPresenti[wizTabOrariAttiva];
        if (!nome) return;
        const o = {};
        CAMPI_ORARI.forEach(f => { const el = document.getElementById('wt_'+f); if(el) o[f] = el.value; });
        o.p = document.getElementById('wt_p')?.checked || false;
        o.c = document.getElementById('wt_c')?.checked || false;
        o.h = document.getElementById('wt_h')?.checked || false;
        g.orari[nome] = o;
    }

    function wizCopiaOrariSuTutti() {
        const g = wizGiornoCorrente();
        if (!g || g.tecniciPresenti.length < 2) return;
        wizSalvaOrariTabCorrente();
        const orariBase = { ...g.orari[g.tecniciPresenti[wizTabOrariAttiva]] };
        for (let i = 0; i < g.tecniciPresenti.length; i++) {
            if (i !== wizTabOrariAttiva) g.orari[g.tecniciPresenti[i]] = { ...orariBase };
        }
        wizRenderGiorno();
        alert('✅ Orari copiati su tutti i tecnici di questa giornata.');
    }

    // Sincronizza tutte le giornate → righe tabella A4
    function wizSyncAllOrariA4() {
        wizSalvaOrariTabCorrente();
        // Pulisce la tabella A4 e ricostruisce: una riga per ogni (giornata × tecnico-presente)
        document.getElementById('table-body').innerHTML = '';
        rowCount = 0;
        wizGiornate.forEach(g => {
            const dataTab = g.data ? (d => `${d[2]}/${d[1]}/${d[0]}`)(g.data.split('-')) : '';
            g.tecniciPresenti.forEach(nome => {
                addRow();
                const i = rowCount;
                const o = g.orari[nome] || {};
                if (document.getElementsByName(`d_${i}`)[0])   document.getElementsByName(`d_${i}`)[0].value   = dataTab;
                if (document.getElementsByName(`tec_${i}`)[0]) document.getElementsByName(`tec_${i}`)[0].value = nome;
                CAMPI_ORARI.forEach(f => {
                    const el = document.getElementsByName(`${f}_${i}`)[0];
                    if (el) el.value = o[f] || '';
                });
                ['p','c','h'].forEach(f => {
                    const el = document.getElementsByName(`${f}_${i}`)[0];
                    if (el) el.checked = !!o[f];
                });
            });
        });
        if (rowCount === 0) addRow(); // mantieni almeno una riga vuota
        calc();
    }

    // ── STEP 4: DESCRIZIONE CON STRUTTURA FISSA ───────────────
    function wizAggiornaTesto() {
        const problema = (document.getElementById('w_problema')?.value || '').trim().toUpperCase();
        const lavoro   = (document.getElementById('w_lavoro')?.value   || '').trim().toUpperCase();
        const testo = [
            problema ? 'PROBLEMA RISCONTRATO:\n' + problema : 'PROBLEMA RISCONTRATO:\n[NON SPECIFICATO]',
            '',
            '----------------------------------------',
            'LAVORO ESEGUITO:',
            lavoro || '',
            '',
            'MACCHINA LASCIATA AL CLIENTE IN FUNZIONE E IN CONDIZIONE DI SICUREZZA'
        ].join('\n');
        document.getElementById('descrizione_input').value = testo;
        saveDraft();
    }

    function wizContaChar() {
        const n = (document.getElementById('w_lavoro')?.value || '').trim().length;
        const el = document.getElementById('w-char-bar');
        if (!el) return;
        el.textContent = n + ' caratteri' + (n < 10 ? ' — scrivi ancora un po\'' : n < 40 ? ' — quasi pronto' : ' ✓');
        el.className = 'char-bar ' + (n < 10 ? 'warn' : 'ok');
    }

    // ── STEP 4c: ANTEPRIMA A4 ────────────────────────────────
    function wizApriA4PerRevisione() {
        wizSyncAllOrariA4();
        wizAggiornaTesto();
        setMode('a4');
        // Mostra banner di ritorno al wizard
        let banner = document.getElementById('wiz-ritorno-banner');
        if (!banner) {
            banner = document.createElement('div');
            banner.id = 'wiz-ritorno-banner';
            banner.style.cssText = 'position:fixed; bottom:0; left:0; right:0; background:var(--tmc-blue); color:white; padding:14px 20px; display:flex; justify-content:space-between; align-items:center; z-index:9000; font-size:14px; font-weight:bold;';
            banner.innerHTML = '<span>✅ Controllo completato?</span><button onclick="wizRitornaDopoRevisione()" style="background:white; color:var(--tmc-blue); border:none; border-radius:5px; padding:10px 18px; font-weight:bold; cursor:pointer; font-size:14px;">Torna al wizard →</button>';
            document.body.appendChild(banner);
        }
        banner.style.display = 'flex';
    }

    function wizRitornaDopoRevisione() {
        const banner = document.getElementById('wiz-ritorno-banner');
        if (banner) banner.style.display = 'none';
        setMode('wizard');
        // Mostra sezione conferma nello step 4c
        document.getElementById('ws4c-conferma').style.display = 'block';
        document.getElementById('w_revisione_ok').checked = false;
    }

    function wizCheckRevisione() {
        // niente da fare, la validazione avviene al goNext
    }



    // ── MATERIALI ──────────────────────────────────────────────
    // Flag per avviso non bloccante step 4b
    let wizCur4bAvvisato = false;

    function wizVal4b() {
        // Non blocca più: restituisce sempre true
        // La sincronizzazione avviene in wizGoNext
        document.getElementById('werr4b').style.display = 'none';
        return true;
    }

    function matBuildLista(materiali) {
        matDaCalendario = materiali;
        const container = document.getElementById('mat-lista-calendario');
        container.innerHTML = '';
        if (!materiali || materiali.length === 0) {
            container.innerHTML = '<p style="font-size:13px; color:#888; text-align:center; padding:1rem 0;">Nessun materiale trovato nel calendario per questo intervento.</p>';
            return;
        }
        materiali.forEach((mat, idx) => {
            const div = document.createElement('div');
            div.className = 'mat-item';
            div.innerHTML = `
                <input type="checkbox" class="mat-check" id="mat-cb-${idx}"
                    onchange="matToggle(${idx}, this.checked)">
                <label for="mat-cb-${idx}" class="mat-testo" id="mat-lbl-${idx}">${mat.testo}</label>
                <input type="number" class="mat-qta" id="mat-qta-${idx}"
                    value="${mat.qtaSuggerita}" min="1" disabled
                    onchange="matSyncA4()">
            `;
            container.appendChild(div);
        });
    }

    function matToggle(idx, checked) {
        const lbl = document.getElementById('mat-lbl-' + idx);
        const qta = document.getElementById('mat-qta-' + idx);
        if (lbl) lbl.className = 'mat-testo' + (checked ? ' usato' : '');
        if (qta) qta.disabled = !checked;
        matSyncA4();
    }

    function matAggiungiExtra() {
        const testo = document.getElementById('mat-nuovo-testo').value.trim().toUpperCase();
        const qta   = parseInt(document.getElementById('mat-nuovo-qta').value) || 1;
        if (!testo) { document.getElementById('mat-nuovo-testo').focus(); return; }
        matExtra.push({ testo, qta });
        document.getElementById('mat-nuovo-testo').value = '';
        document.getElementById('mat-nuovo-qta').value  = '1';
        matRenderExtra();
        matSyncA4();
    }

    function matRenderExtra() {
        const container = document.getElementById('mat-extra-list');
        container.innerHTML = '';
        matExtra.forEach((m, idx) => {
            const div = document.createElement('div');
            div.className = 'mat-extra-item';
            div.innerHTML = `
                <input type="number" value="${m.qta}" min="1" style="width:54px; padding:6px 4px; border:1px solid #cce0f5; border-radius:5px; font-size:15px; font-weight:bold; color:var(--tmc-blue); text-align:center; background:white;"
                    onchange="matExtra[${idx}].qta=parseInt(this.value)||1; matSyncA4();">
                <input type="text" class="mat-extra-testo" value="${m.testo}"
                    onchange="matExtra[${idx}].testo=this.value.toUpperCase(); matSyncA4();">
                <button class="mat-extra-del" onclick="matRimuoviExtra(${idx})">×</button>
            `;
            container.appendChild(div);
        });
    }

    function matRimuoviExtra(idx) {
        matExtra.splice(idx, 1);
        matRenderExtra();
        matSyncA4();
    }

    // Sincronizza materiali selezionati → tabella ricambi A4
    function matSyncA4() {
        // Svuota tutte le righe ricambi esistenti
        document.getElementById('ricambi-body').innerHTML = '';
        ricCount = 0;

        // 1. Materiali dal calendario flaggati
        matDaCalendario.forEach((mat, idx) => {
            const cb  = document.getElementById('mat-cb-' + idx);
            const qtaEl = document.getElementById('mat-qta-' + idx);
            if (cb && cb.checked) {
                addRicambioConDati('', mat.testo, qtaEl ? qtaEl.value : 1, '', '');
            }
        });

        // 2. Materiali extra
        matExtra.forEach(m => {
            addRicambioConDati('', m.testo, m.qta, '', '');
        });

        calc();
    }

    // Aggiunge una riga ricambio già precompilata nella tabella A4
    function addRicambioConDati(codice, descrizione, qta, unitPrice, totale) {
        ricCount++;
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td><input type="text" class="save-data caps" name="rc_${ricCount}" value="${codice}"></td>
            <td><input type="text" class="save-data caps" name="rd_${ricCount}" value="${descrizione.toUpperCase()}"></td>
            <td><input type="number" class="save-data qta" name="rq_${ricCount}" value="${qta}"></td>
            <td><input type="text" class="save-data unit" name="ru_${ricCount}" value="${unitPrice}"></td>
            <td><input type="text" class="save-data tot-riga" name="rt_${ricCount}" value="${totale}"></td>
        `;
        document.getElementById('ricambi-body').appendChild(tr);
        attachListeners();
    }

    // ── FINE MATERIALI ─────────────────────────────────────────

    function wizToggleTec(btn) {
        btn.classList.toggle('sel');
        wizSyncTecnici();
    }

    // Tecnici extra (non in lista) — array di nomi stringa
    let wizTecExtra = [];

    function wizAgiungiTecExtra() {
        const input = document.getElementById('wiz-tec-extra-input');
        const nome = input.value.trim().toUpperCase();
        if (!nome || wizTecExtra.includes(nome)) { input.focus(); return; }
        wizTecExtra.push(nome);
        input.value = '';
        wizRenderTecExtra();
        wizSyncTecnici();
    }

    function wizAgiungiTecNomeEsterno(nome) {
        if (!wizTecExtra.includes(nome)) {
            wizTecExtra.push(nome);
            wizRenderTecExtra();
        }
        wizSyncTecnici();
    }

    function wizRimuoviTecExtra(nome) {
        wizTecExtra = wizTecExtra.filter(n => n !== nome);
        wizRenderTecExtra();
        wizSyncTecnici();
    }

    function wizRenderTecExtra() {
        const container = document.getElementById('wiz-tec-extra-list');
        container.innerHTML = '';
        wizTecExtra.forEach(nome => {
