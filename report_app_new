    async function verificaLogin() {
        if(!navigator.onLine) return alert("Sei offline. Attiva la connessione per il primo login.");
        const input = document.getElementById('pin_input').value.toUpperCase().trim();
        const btn = document.getElementById('btn-login');
        if(!input) return;
        btn.innerText = "VERIFICA IN CORSO...";
        document.getElementById('login-error').style.display = 'none';
        try {
            const response = await fetch(APP_SCRIPT_URL, {
                method: "POST", headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                body: JSON.stringify({ action: "check_pin", pin: input })
            });
            const data = await response.json();
            if(data.success) {
                localStorage.setItem('tmc_auth_token', input);
                // Controlla se l'email tecnico è già stata impostata
                const emailTec = localStorage.getItem('tmc_email_tecnico');
                if (emailTec === null) {
                    // Prima volta: mostra overlay raccolta email
                    document.getElementById('login-overlay').style.display = 'none';
                    document.getElementById('email-tecnico-overlay').style.display = 'flex';
                    setTimeout(() => document.getElementById('email_tecnico_input').focus(), 200);
                } else {
                    sbloccaApp();
                }
            } else {
                document.getElementById('login-error').style.display = 'block';
            }
        } catch(e) { alert("Errore di connessione. Riprova."); }
        finally { btn.innerText = "ACCEDI"; }
    }

