    function generaRiepilogoCalendario(idUnivoco) { let r=`\n\n--- RAPPORTO INVIATO (${idUnivoco}) ---\n`; let lav=document.getElementById('tot_lavoro_span')?.innerText||""; if(lav) r+=`Ore: ${lav}\n`; let totP=0,totC=0,totH=0; for(let i=1;i<=rowCount;i++){ if(document.getElementsByName(`p_${i}`)[0]?.checked)totP++; if(document.getElementsByName(`c_${i}`)[0]?.checked)totC++; if(document.getElementsByName(`h_${i}`)[0]?.checked)totH++; } if(totP+totC>0)r+=`Pasti: ${totP+totC}\n`; if(totH>0)r+=`Hotel: ${totH}\n`; let ric=[]; for(let i=1;i<=ricCount;i++){let d=document.getElementsByName(`rd_${i}`)[0]?.value; let q=document.getElementsByName(`rq_${i}`)[0]?.value; if(d&&q&&parseFloat(q)>0)ric.push(`- ${q}x ${d.toUpperCase()}`);} if(ric.length>0)r+=`Ricambi:\n${ric.join('\n')}\n`; return r; }
    function condividiWhatsApp() { if(!validaCampiObbligatori())return; if(!navigator.onLine){alert("📵 Offline!");return;} if(!controllaFirma())return; generaIdUnivoco(); const element=document.getElementById('rapporto-foglio'); const idU=document.getElementById('id_univoco_input').value; const nc=document.getElementById('cliente_input').value||'Cliente'; const fn=`Rapporto_${idU}_${nc}.pdf`.replace(/ /g,"_"); let tckVal=document.getElementById('n_rapporto_input').value; if(!tckVal.startsWith("TCK-"))tckVal="TCK-"+tckVal; let inviati=JSON.parse(localStorage.getItem('tmc_ticket_inviati')||'[]'); if(inviati.includes(tckVal)){if(!confirm("⚠️ Già chiuso. Vuoi aggiornare?"))return;} let testoCal=document.getElementById('descrizione_input').value; if(testoCal.indexOf("RAPPORTO INVIATO")===-1)testoCal+=generaRiepilogoCalendario(idU); document.getElementById('loading-overlay').style.display='flex'; document.getElementById('loading-text').innerText="Aggiornamento Calendario..."; fetch(APP_SCRIPT_URL,{method:"POST",headers:{'Content-Type':'text/plain;charset=utf-8'},body:JSON.stringify({action:"close_ticket",ticket:tckVal,updateCalendario:testoCal,pin:localStorage.getItem('tmc_auth_token')})}).then(()=>{ if(!inviati.includes(tckVal)){inviati.push(tckVal);localStorage.setItem('tmc_ticket_inviati',JSON.stringify(inviati));} let bl=JSON.parse(localStorage.getItem('tmc_bozze_locali')||'[]').filter(b=>b.tck!==tckVal); localStorage.setItem('tmc_bozze_locali',JSON.stringify(bl)); document.getElementById('loading-text').innerText="Generazione PDF..."; preparaSchermoPerPDF(); setTimeout(()=>{html2pdf().set(getPdfOptions(fn)).from(element).output('blob').then(pdfBlob=>{ripristinaSchermo(); document.getElementById('loading-overlay').style.display='none'; const file=new File([pdfBlob],fn,{type:'application/pdf'}); if(navigator.canShare&&navigator.canShare({files:[file]})){navigator.share({title:'Rapporto TMC',text:'In allegato il rapporto.',files:[file]});}else{html2pdf().set(getPdfOptions(fn)).from(element).save();alert("Scaricato.");} }).catch(err=>{ripristinaSchermo(); document.getElementById('loading-overlay').style.display='none';});},100);}); }
    function inviaEmailAutomaticamente() {
        if(!validaCampiObbligatori()) return;
        if(!navigator.onLine) return alert("📵 Offline!");
        if(!controllaFirma()) return;
        generaIdUnivoco();
        const element = document.getElementById('rapporto-foglio');
        const idU = document.getElementById('id_univoco_input').value;
        let tckVal = document.getElementById('n_rapporto_input').value;
        if(!tckVal.startsWith("TCK-")) tckVal = "TCK-" + tckVal;
        let inviati = JSON.parse(localStorage.getItem('tmc_ticket_inviati') || '[]');
        if(inviati.includes(tckVal)) { if(!confirm("⚠️ Già inviato. Ri-inviare?")) return; }
        let testoCal = document.getElementById('descrizione_input').value;
        if(testoCal.indexOf("RAPPORTO INVIATO") === -1) testoCal += generaRiepilogoCalendario(idU);
        const emailCliente = document.getElementById('email_input').value || '';
        const nomeCliente  = document.getElementById('cliente_input').value || 'Cliente';
        const tecnico      = document.getElementsByName('tecnico_1')[0]?.value || '';
        document.getElementById('loading-overlay').style.display = 'flex';
        document.getElementById('loading-text').innerText = "Generazione PDF...";
        preparaSchermoPerPDF();
        setTimeout(() => {
            html2pdf().set(getPdfOptions(tckVal)).from(element).outputPdf('datauristring').then(pdfBase64 => {
                ripristinaSchermo();
                document.getElementById('loading-text').innerText = "Invio in corso...";
                const emailTecnico = localStorage.getItem('tmc_email_tecnico') || '';
                fetch(APP_SCRIPT_URL, {
                    method: "POST",
                    headers: {'Content-Type':'text/plain;charset=utf-8'},
                    body: JSON.stringify({
                        action: "send_email", pdfBase64,
                        ticket: tckVal, updateCalendario: testoCal,
                        pin: localStorage.getItem('tmc_auth_token'),
                        filename: `Rapporto_${idU}.pdf`,
                        nomeCliente, emailCliente, tecnico,
                        emailTecnico   // ← copia di conferma al tecnico
                    })
                }).then(r => r.json()).then(data => {
                    document.getElementById('loading-overlay').style.display = 'none';
                    if(data.success) {
                        // Usa la lista destinatari restituita dal server
                        const dest = data.destinatari || 'tmcservice@tmcservice.it, info@tmcservice.it';
                        mostraEsitoEmail(true,
                            'Il rapporto è stato consegnato correttamente. Il calendario è stato aggiornato.',
                            dest
                        );
                        if(!inviati.includes(tckVal)) {
                            inviati.push(tckVal);
                            localStorage.setItem('tmc_ticket_inviati', JSON.stringify(inviati));
                        }
                        let bl = JSON.parse(localStorage.getItem('tmc_bozze_locali') || '[]').filter(b => b.tck !== tckVal);
                        localStorage.setItem('tmc_bozze_locali', JSON.stringify(bl));
                        document.getElementById('er-btn-ok').onclick = () => { chiudiEsitoEmail(); nuovoRapporto(); };
                    } else {
                        mostraEsitoEmail(false,
                            'Errore dal server: ' + (data.error || 'Sconosciuto') + '\n\nRiprova o contatta l\'ufficio.',
                            null
                        );
                    }
                }).catch(() => {
                    document.getElementById('loading-overlay').style.display = 'none';
                    mostraEsitoEmail(false,
                        'Errore di rete durante l\'invio. Controlla la connessione e riprova.',
                        null
                    );
                });
            });
        }, 500);
    }
