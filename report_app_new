    <div id="loading-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:10000; color:white; flex-direction:column; justify-content:center; align-items:center; font-family:sans-serif; font-weight:bold; text-align:center; padding:20px;">
