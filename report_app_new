    function modalAutoFill(el) { const selects=Array.from(document.querySelectorAll('.modal-time-select')); const idx=selects.indexOf(el); if(idx!==-1&&idx<selects.length-1){ const next=selects[idx+1]; if(next&&!next.value)next.value=el.value; } }
    function addRicambio() { ricCount++; const tr=document.createElement('tr'); tr.innerHTML=`<td><input type="text" class="save-data caps" name="rc_${ricCount}"></td><td><input type="text" class="save-data caps" name="rd_${ricCount}"></td><td><input type="number" class="save-data qta" name="rq_${ricCount}"></td><td><input type="text" class="save-data unit" name="ru_${ricCount}"></td><td><input type="text" class="save-data tot-riga" name="rt_${ricCount}"></td>`; document.getElementById('ricambi-body').appendChild(tr); attachListeners(); }
    function calc() { function toMin(t){if(!t||t===RIT_LABEL)return 0; const p=t.split(':'); return parseInt(p[0])*60+parseInt(p[1]);} const getDiff=(t1,t2)=>{ if(!t1||!t2||t2===RIT_LABEL)return 0; let m1=toMin(t1),m2=toMin(t2); if(m2<m1)m2+=1440; return m2-m1;}; let totL=0,totV=0,totP=0,totC=0,totH=0,hasRit=false; for(let i=1;i<=rowCount;i++){ const g=(n)=>document.getElementsByName(`${n}_${i}`)[0]?.value||""; const gc=(n)=>document.getElementsByName(`${n}_${i}`)[0]?.checked||false; let va1=g('va1'),va2=g('va2'),lm1=g('lm1'),lm2=g('lm2'),lp1=g('lp1'),lp2=g('lp2'),vr1=g('vr1'),vr2=g('vr2'); if(vr2===RIT_LABEL)hasRit=true; let mv=getDiff(va1,va2)+getDiff(vr1,vr2); let ml=getDiff(lm1,lm2)+getDiff(lp1,lp2); totV+=mv; totL+=ml; let tot=mv+ml; const div=document.getElementById(`ore_riga_${i}`); if(div){ if(tot>0){let h=Math.floor(tot/60),m=tot%60; div.innerText=`${h}h${m>0?' '+m+'m':''}`;}else div.innerText=""; } if(gc('p'))totP++; if(gc('c'))totC++; if(gc('h'))totH++; } const fmt=(m)=>{ if(m===0)return""; let h=Math.floor(m/60),m2=m%60; return`${h}h${m2>0?' '+m2+'m':''}`.trim();}; let all=totL+totV; let lbl=all>0?fmt(all):""; if(hasRit&&lbl)lbl+=" + ritorno"; const sl=document.getElementById('tot_lavoro_span'); const sp=document.getElementById('tot_pch_span'); const sh=document.getElementById('tot_hotel_span'); if(sl)sl.innerText=lbl; if(sp)sp.innerText=totP+totC>0?`${totP+totC}`:""; if(sh)sh.innerText=totH>0?`${totH}`:""; saveDraft(); }
    function openSignature() { const ov=document.getElementById('signature-overlay'); ov.style.display='flex'; canvas.width=canvas.offsetWidth; canvas.height=canvas.offsetHeight; ctx.lineWidth=3; ctx.strokeStyle="#000"; ctx.lineCap="round"; }
    function closeSignature(save) { if(save){ const url=canvas.toDataURL(); document.getElementById('sig-image').src=url; document.getElementById('sig-image').style.display='block'; document.getElementById('placeholder-firma').style.display='none'; localStorage.setItem('tmc_sig',url); const wb=document.getElementById('wiz-sigbox'); if(wb){ wb.className='sig-area signed'; wb.innerHTML='<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 24 Q10 14 16 20 Q22 26 28 8"/><line x1="4" y1="28" x2="28" y2="28"/></svg><span>Firma acquisita ✓</span>'; } } document.getElementById('signature-overlay').style.display='none'; }
    function clearSignature(){ctx.clearRect(0,0,canvas.width,canvas.height);}
    function getPos(e){const r=canvas.getBoundingClientRect(); const cx=e.touches?e.touches[0].clientX:e.clientX; const cy=e.touches?e.touches[0].clientY:e.clientY; return{x:cx-r.left,y:cy-r.top};}
    canvas.addEventListener('touchstart',e=>{drawing=true;ctx.beginPath();const p=getPos(e);ctx.moveTo(p.x,p.y);e.preventDefault();});
    canvas.addEventListener('touchmove',e=>{if(!drawing)return;const p=getPos(e);ctx.lineTo(p.x,p.y);ctx.stroke();e.preventDefault();});
    canvas.addEventListener('touchend',()=>drawing=false);
    function saveDraft(){const data={};document.querySelectorAll('.save-data').forEach(el=>data[el.name]=(el.type==='checkbox'?el.checked:el.value));localStorage.setItem('tmc_bozza',JSON.stringify(data));localStorage.setItem('tmc_counts',JSON.stringify({r:rowCount,ric:ricCount}));}
    function loadDraft(){const counts=JSON.parse(localStorage.getItem('tmc_counts')||'{"r":1,"ric":1}');document.getElementById('table-body').innerHTML="";document.getElementById('ricambi-body').innerHTML="";rowCount=0;ricCount=0;for(let i=0;i<counts.r;i++)addRow();for(let i=0;i<counts.ric;i++)addRicambio();const saved=JSON.parse(localStorage.getItem('tmc_bozza')||'{}');if(!saved['descrizione']||saved['descrizione'].trim()==="")saved['descrizione']=FRASE_SICUREZZA;let tCount=1;while(saved['tecnico_'+tCount]!==undefined){if(tCount>1)aggiungiRigaTecnico(saved['tecnico_'+tCount],false);else document.getElementsByName('tecnico_1')[0].value=(saved['tecnico_1']||"").toUpperCase();tCount++;}document.querySelectorAll('.save-data').forEach(el=>{if(saved[el.name]!==undefined)el.type==='checkbox'?el.checked=saved[el.name]:el.value=saved[el.name];});const sig=localStorage.getItem('tmc_sig');if(sig){document.getElementById('sig-image').src=sig;document.getElementById('sig-image').style.display='block';document.getElementById('placeholder-firma').style.display='none';}else{document.getElementById('sig-image').src="";document.getElementById('sig-image').style.display='none';document.getElementById('placeholder-firma').style.display='inline';}setTipo(saved['tipo_int']||'P');
    // Ripristina campi wizard
    if(saved['n_rapporto'])document.getElementById('w_ticket').value=saved['n_rapporto'];
    if(saved['cliente'])document.getElementById('w_cliente').value=saved['cliente'];
    if(saved['indirizzo'])document.getElementById('w_indirizzo').value=saved['indirizzo'];
    if(saved['macchina'])document.getElementById('w_matricola').value=saved['macchina'];
    if(saved['email_cliente'])document.getElementById('w_email').value=saved['email_cliente'];
    if(saved['mezzo_trasporto'])document.getElementById('w_mezzo').value=saved['mezzo_trasporto'];
    // Ripristina problema/lavoro dai campi A4 (descrizione contiene il testo unificato)
    if(saved['descrizione']) {
        const desc = saved['descrizione'];
        const mProb = desc.match(/PROBLEMA RISCONTRATO:\n?([\s\S]*?)(?:\n-{4,}|\nLAVORO ESEGUITO:|$)/i);
        const mLav  = desc.match(/LAVORO ESEGUITO:\n?([\s\S]*?)(?:\nMACCHINA LASCIATA|$)/i);
        if(document.getElementById('w_problema') && mProb) document.getElementById('w_problema').value = mProb[1].trim();
        if(document.getElementById('w_lavoro')   && mLav)  document.getElementById('w_lavoro').value   = mLav[1].trim();
    }
    // Ripristina tecnici wizard
    const t1=saved['tecnico_1'];
    if(t1){document.querySelectorAll('#wiz-tec-grid .tec-btn').forEach(btn=>{if(btn.textContent.trim()===t1.trim())btn.classList.add('sel');});}
    wizContaChar();
    calc();}
    function attachListeners(){document.querySelectorAll('.save-data').forEach(el=>{el.oninput=calc;});}
    function nuovoRapporto(){if(confirm("Cancellare tutto e iniziare un nuovo rapporto?")){localStorage.removeItem('tmc_bozza');localStorage.removeItem('tmc_counts');localStorage.removeItem('tmc_sig');location.reload();}}
    window.addEventListener('beforeprint',preparaSchermoPerPDF);
    window.addEventListener('afterprint',ripristinaSchermo);
    // Init data wizard al giorno corrente
    // (w_data rimosso: ora le date sono gestite per giornata in wizGiornate)
    window.onload = function(){
        const savedPin = localStorage.getItem('tmc_auth_token');
        if(savedPin && savedPin !== '') sbloccaApp();
        else { document.getElementById('login-overlay').style.display = 'flex'; document.getElementById('app-content').style.display = 'none'; }
        document.getElementById('pin_input').addEventListener("keypress", function(e){ if(e.key==="Enter"){ e.preventDefault(); verificaLogin(); } });
        document.getElementById('email_tecnico_input').addEventListener("keypress", function(e){ if(e.key==="Enter"){ e.preventDefault(); salvaEmailTecnico(); } });
        wizUpdateProgress();
    };
    </script>
